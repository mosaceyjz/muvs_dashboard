# Chengdu 6F MUVS dashboard server environment template
# Copy this file to .env on the target server before running npm start

# SQL Server connection
DB_SERVER=PRCCJ-MSGCR01
DB_DATABASE=MUVS
DB_USER=sa
DB_PASSWORD=xxxx
DB_PORT=1433

# Dashboard web server
# Use 0.0.0.0 so other PCs on the same LAN can open the dashboards
APP_HOST=0.0.0.0
APP_PORT=3036

# API cache
# 60000 = 60 seconds. Keeps repeated screen refreshes from hitting SQL every time.
DASHBOARD_CACHE_TTL_MS=60000

# Optional notes
# Main dashboard:     http://<server-ip>:3036/
# Operator board:     http://<server-ip>:3036/board
# Navigation portal:  http://<server-ip>:3036/nav
# Current recommended auth mode: SQL login verified with this project.
# If you later change the SQL account, only DB_USER and DB_PASSWORD need updating.
